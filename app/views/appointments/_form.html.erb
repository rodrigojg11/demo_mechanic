<%= turbo_frame_tag "booking_form", class: "booking-body" do %>
  <%= simple_form_for appointment_request,
    as: :appointment_request,
    url: appointments_path,
    html: { data: { turbo_frame: "booking_form", booking_target: "form", availability_url: availability_appointments_path } } do |f| %>

    <% if appointment_request.errors.any? %>
      <div class="alert alert-danger mb-4" role="alert">
        <strong>We could not request this appointment.</strong>
        <ul class="mb-0 mt-2">
          <% appointment_request.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.input :service_slug, as: :hidden, input_html: { data: { booking_target: "serviceInput" } } %>
    <%= f.input :scheduled_on, as: :hidden, input_html: { data: { booking_target: "dateInput" } } %>
    <%= f.input :scheduled_time, as: :hidden, input_html: { data: { booking_target: "timeInput" } } %>
    <%= f.input :payment_preference, as: :hidden, input_html: { value: appointment_request.payment_preference.presence || "pay_after_service", data: { booking_target: "paymentInput" } } %>

    <div class="booking-title">
      <small>Step 1 of 4</small>
      <h4>Choose a service</h4>
      <p>If you do not see what you need, add it in the notes.</p>
    </div>

    <div class="booking-options">
      <% services.each do |service| %>
        <button class="booking-option" type="button" data-booking-target="serviceOption" data-service="<%= service[:id] %>" data-service-name="<%= service[:name] %>" data-action="booking#selectService">
          <strong><%= service[:name] %></strong>
          <p><%= service[:desc] %></p>
          <footer><span><%= service[:duration] %> min</span><span>$<%= service[:price] %></span></footer>
        </button>
      <% end %>
    </div>

    <div class="booking-title mt-5">
      <small>Step 2 of 4</small>
      <h4>Choose a date</h4>
      <p>Closed on Sundays. Saturdays are available until 2pm.</p>
    </div>

    <div class="calendar-grid compact-calendar">
      <% 21.times.map { |offset| Time.zone.today + offset.days }.reject(&:sunday?).first(14).each do |date| %>
        <button class="day-btn" type="button" data-booking-target="dateOption" data-date="<%= date.iso8601 %>" data-saturday="<%= date.saturday? %>" data-action="booking#selectDate">
          <strong><%= date.day %></strong>
          <small><%= date.strftime("%a") %></small>
        </button>
      <% end %>
    </div>

    <div class="booking-title mt-5">
      <small>Step 3 of 4</small>
      <h4>Choose a time</h4>
      <p>Unavailable slots will be blocked by the booking rules before saving.</p>
    </div>

    <div class="slot-grid" data-booking-target="slots">
      <span class="slot-empty">Select a service and date to see available times.</span>
    </div>

    <div class="booking-title mt-5">
      <small>Payment</small>
      <h4>Choose how to pay</h4>
      <p>Payment is optional now. You can still request the appointment and pay after service.</p>
    </div>

    <div class="booking-options payment-options">
      <button class="booking-option" type="button" data-booking-target="paymentOption" data-payment="pay_after_service" data-action="booking#selectPayment">
        <strong>Pay after service</strong>
        <p>Request the appointment now and pay when the work is done.</p>
      </button>
      <button class="booking-option" type="button" data-booking-target="paymentOption" data-payment="pay_now" data-action="booking#selectPayment">
        <strong>Pay now</strong>
        <p>Reserve the appointment now. Stripe will be connected later.</p>
      </button>
    </div>

    <div class="booking-title mt-5">
      <small>Step 4 of 4</small>
      <h4>Your vehicle</h4>
      <p>You will receive appointment updates at the phone number you provide.</p>
    </div>

    <div class="form-grid">
      <%= f.input :name, label: "Name", placeholder: "Your name", wrapper_html: { class: "field" } %>
      <%= f.input :phone, label: "Phone", placeholder: "(214) 555-0123", wrapper_html: { class: "field" } %>
      <%= f.input :email, label: "Email", placeholder: "you@example.com", wrapper_html: { class: "field full" } %>
      <%= f.input :make, label: "Vehicle make", placeholder: "Toyota, Ford, Chevy...", wrapper_html: { class: "field" } %>
      <%= f.input :model, label: "Model", placeholder: "Camry, F-150, Silverado...", wrapper_html: { class: "field" } %>
      <%= f.input :year, label: "Year", placeholder: "2020", wrapper_html: { class: "field full" } %>
      <%= f.input :notes, as: :text, label: "Symptoms / notes", placeholder: "Noises, warning lights, what is happening...", wrapper_html: { class: "field full" } %>
    </div>

    <div class="booking-actions">
      <span data-booking-target="summary">Select service, date, and time</span>
      <%= f.button :submit, "Request appointment", class: "btn", data: { booking_target: "submitButton" } %>
    </div>
  <% end %>
<% end %>
